# ============================================================
#  Westwood AI - YOLO Trainer  |  Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# ---------------------------
# Roboflow
# ---------------------------
ROBOFLOW_API_KEY=your_roboflow_api_key_here
ROBOFLOW_WORKSPACE=westwood-ai
ROBOFLOW_PROJECT=westwoodobjectdetection-bmbpt
ROBOFLOW_VERSION=16
ROBOFLOW_EXPORT_FORMAT=yolov11

# ---------------------------
# AWS S3
# ---------------------------
AWS_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=us-east-1

# ---------------------------
# SNS Notifications (optional)
# Leave blank to disable SNS notifications.
# ---------------------------
SNS_TOPIC_ARN=

# ---------------------------
# Training Defaults
# These can also be overridden at runtime via CLI flags.
# ---------------------------
MODEL_PATH=yolov8n.pt
EPOCHS=100
# CHECKPOINT_WEIGHTS=/path/to/weights.pt   # uncomment to resume from a checkpoint
